---
import { TAG_STYLES } from '@/lib/icons';

interface Props {
  kind: string;
}

const { kind } = Astro.props;
const s = TAG_STYLES[kind] ?? TAG_STYLES.AJUSTE;
---

<span
  class="inline-flex items-center gap-1.5 font-mono text-[11px] tracking-[0.04em] uppercase px-2 py-[3px] rounded-[3px]"
  style={`background:${s.bg};color:${s.fg};`}
>
  <span class="w-1 h-1 rounded-full" style={`background:${s.dot};`}></span>
  {kind}
</span>
