---
import Icon from '@/components/ui/Icon.astro';
import type { DevNotes } from '@/lib/types';

interface Props {
  notes: DevNotes;
}

const { notes } = Astro.props;
---

<blockquote
  class="rounded-md border relative overflow-hidden"
  style="background:var(--panel);border-color:var(--border);"
>
  <div
    class="absolute left-0 top-0 bottom-0 w-[3px]"
    style="background:var(--accent);"
  ></div>
  <div class="pl-6 pr-5 py-5">
    <div
      class="flex items-center gap-2 font-mono text-[10.5px] uppercase tracking-[0.14em] mb-3"
      style="color:var(--accent);"
    >
      <Icon name="pin" size={11} />
      Exposición de motivos · parafraseada
    </div>
    <p
      class="font-serif text-[18px] leading-[1.55]"
      style="color:var(--text);text-wrap:pretty;"
    >
      &ldquo;{notes.quote}&rdquo;
    </p>
    <footer class="mt-4 text-[12.5px]" style="color:var(--muted);">
      — {notes.attribution}
    </footer>
  </div>
</blockquote>
